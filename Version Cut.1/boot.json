{
    "name": "Dynamicest",
    "nickName": "极致动态 仅状态条美化",
    "version": "cut.1",
    "styleFileList": ["dynamicest.css"],
    "scriptFileList": ["dynamicest.js"],
    "tweeFileList": ["settings.twee"],
    "imgFileList": [
        "img/dynamicest/logo.png"
    ],
    "addonPlugin": [
        {
            "modName": "TweeReplacer",
            "addonName": "TweeReplacerAddon",
            "modVersion": "^1.0.0",
            "params": [
                {
                    "passage": "overlayReplace",
                    "findRegex": "<<optionsinformation>><<\\/replace>>[\\s\\S]*?<<\\/button>>", 
                    "regexFlag": "g",  
                    "replace": "<<optionsinformation>><</replace>>\n\t\t<</button>><<dynamicestModTab>>"
                }
            ]
        },
        {
            "modName": "ModLoader DoL ImageLoaderHook",
            "addonName": "ImageLoaderAddon",
            "modVersion": "^2.3.0",
            "params": []
        }
    ],
    "dependenceInfo": [
        
        {
            "modName": "ModLoader",
            "version": "^2.31.2"
        },
        {
            "modName": "TweeReplacer",
            "version": "^1.0.0"
        },
        {
            "modName": "ModLoader DoL ImageLoaderHook",
            "version": "^2.3.0"
        }
    ]
}